          }
        },
        "required": ["severity", "message"],
        "type": "object"
      },
      "type": "array"
    },
    "summary": {
      "type": "string"
    },
    "verdict": {
      "enum": ["PASS", "FAIL"],
      "type": "string"
    }
  },
  "required": ["verdict", "findings"],
  "type": "object"
