{
  "dependencies": {
    "@mastra/core": "^1.35.0",
    "@mastra/libsql": "^1.11.0",
    "@mastra/memory": "^1.18.2",
    "commander": "^14.0.3",
    "execa": "^9.5.2",
    "extract-json-from-string": "^1.0.1",
    "gray-matter": "^4.0.3",
    "jsonpath-plus": "^10.4.0",
    "package-manager-detector": "^1.6.0",
    "smol-toml": "^1.6.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^25.9.1",
    "jscpd": "^4.0.5",
    "mastra": "^1.9.3",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.3",
    "ultracite": "7.7.0",
    "vitest": "^3.2.0"
  },
  "name": "@oisincoveney/pipeline",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oisincoveney/agent-pipeline.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "oisin-pipeline": "dist/index.js",
    "pipe": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pipeline-primitive": {
      "types": "./dist/mastra/pipeline-primitive.d.ts",
      "import": "./dist/mastra/pipeline-primitive.js"
    },
    "./runner": {
      "types": "./dist/mastra/runner.d.ts",
      "import": "./dist/mastra/runner.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build:cli": "rm -rf dist && bun build src/index.ts --outfile dist/index.js --target node && bun build src/mastra/pipeline-primitive.ts --outfile dist/mastra/pipeline-primitive.js --target node && bun build src/mastra/runner.ts --outfile dist/mastra/runner.js --target node && tsc -p tsconfig.types.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "pipe": "bun src/index.ts pipe",
    "dev": "mastra dev",
    "build": "bun run build:cli && mastra build",
    "start": "mastra start",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepack": "bun run build:cli"
  },
  "type": "module",
  "version": "1.0.2",
  "description": "",
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=22.13.0",
    "bun": ">=1.1.0"
  }
}
